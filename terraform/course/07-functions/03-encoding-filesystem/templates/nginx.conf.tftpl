# Auto-generated Nginx configuration
# Generated by Terraform templatefile()

%{ for svc in services ~}
upstream ${svc.name} {
    server 127.0.0.1:${svc.port};
}

%{ endfor ~}

server {
    listen ${listen_port};
    server_name ${server_name};

%{ for svc in services ~}
    location /${svc.name} {
        proxy_pass http://${svc.name};
    }

%{ endfor ~}
}
